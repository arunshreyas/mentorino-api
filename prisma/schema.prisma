// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MENTOR
  ADMIN
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

model applications {
  id                   String   @id @default(uuid())
  user_name            String
  user_email           String
  user_phone           String?
  mentor_type          String
  meeting_preference   String?  // 'Virtual', 'In-Person', 'Hybrid'
  frequency            String?  // 'Weekly', 'Bi-weekly', 'Monthly'
  goals                String?
  seriousness           Int?     // 1-5 scale
  attribution          String?
  source               String?
  tags                 Json?    // ["tag1", "tag2"]
  notes                Json?    // ["note1", "note2"]
  status               String   @default("pending") // 'pending', 'approved', 'rejected', 'deleted'
  created_at           DateTime @default(now())
  ai_score             Float?
  pillar               String?
  experience           String?

  @@map("applications")
}

model profiles {
  id         String   @id
  email      String   @unique
  name       String
  password   String
  role       Role     @default(USER)
  tasks      Json     @default("[]")
  created_at DateTime @default(now())
  expertise  Json     @default("[]")
  bio        String?
  profile_image_url String?
  pricing_cents Int?
  timezone   String?

  bookings        bookings[]
  task_activities task_activities[]
  mentorSessions  Session[] @relation("MentorSessions")
  studentSessions Session[] @relation("StudentSessions")
  availabilitySlots MentorAvailability[]

  @@map("profiles")
}

model bookings {
  id        String   @id @default(uuid())
  user_id   String
  user_name String?
  date      String
  time      String
  status    String   @default("upcoming")
  notes     String? 

  user profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model task_activities {
  id                         String   @id @default(uuid())
  user_id                    String
  user_name                  String?
  status                     String   @default("pending")
  admin_response             String?
  pb_card_details            String?
  pb_linkedin_url            String?
  pb_resume_link             String?
  pb_cover_letter_link       String?
  pb_dress_code_notes        String?
  pb_greeting_intro_notes    String?
  net_attended_event         String?
  net_people_met             String?
  net_contact_info           String?
  net_panel_summary          String?
  pw_introduction            String?
  pw_volunteer_hours         String?
  cert_topic                 String?
  roadmap_topic              String?
  interview_recommendation   String?
  created_at                 DateTime @default(now())

  user profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("task_activities")
}

model events {
  id          String   @id @default(uuid())
  title       String
  date        String
  time        String
  location    String
  description String
  link        String?
  attendees   Json     @default("[]")
  created_at  DateTime @default(now())

  @@map("events")
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Session {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  mentorId    String
  studentId   String
  status      SessionStatus @default(SCHEDULED)
  notes       String?
  availabilitySlotId String? @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  mentor      profiles       @relation("MentorSessions", fields: [mentorId], references: [id])
  student     profiles       @relation("StudentSessions", fields: [studentId], references: [id])
  availabilitySlot MentorAvailability? @relation(fields: [availabilitySlotId], references: [id])

  @@index([mentorId, studentId])
  @@index([mentorId, startTime])
  @@index([studentId, startTime])
  @@index([status])
}

model MentorAvailability {
  id        String             @id @default(uuid())
  mentorId  String
  startTime DateTime
  endTime   DateTime
  status    AvailabilityStatus @default(AVAILABLE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  mentor    profiles           @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  session   Session?

  @@unique([mentorId, startTime])
  @@index([mentorId, status, startTime])
}
